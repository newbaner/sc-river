{
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/river", "destination": "/api/river" }
  ],
  "headers": [
    {
      "source": "/api/river",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    }
  ]
}
