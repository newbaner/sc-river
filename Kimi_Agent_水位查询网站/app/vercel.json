{
  "framework": "vite",
  "outputDirectory": "dist",
  "functions": {
    "api/river.js": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/api/river", "destination": "/api/river" }
  ],
  "headers": [
    {
      "source": "/api/river",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" }
      ]
    }
  ]
}
